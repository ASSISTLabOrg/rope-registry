{
  "schema_version": 1,
  "kind": "ensemble_fusion_decoder",
  "runtime_requirements": {
    "onnxruntime": "1.25",
    "libtorch": "2.7"
  },
  "latent_dim": "ten",
  "driver_columns": ["f10", "kp", "t1", "t2", "t3", "t4"],
  "driver_source": "celestrak_sw",
  "validated": false,
  "ensemble_fusion_decoder": {
    "seq_len": 3,
    "decode_batch_size": 120,
    "base_models": [
      { "file": "base_model_00.onnx", "backend": "onnx", "architecture": "lstm", "inter_op_threads": 1 },
      { "file": "base_model_10.onnx", "backend": "onnx", "architecture": "transformer", "inter_op_threads": 2 }
    ],
    "meta_model": { "file": "meta_model.onnx", "backend": "onnx" },
    "decoders": [
      {
        "backends": { "onnx": "coae_decoder.onnx", "libtorch": "coae_decoder.pt" },
        "stats": "stats_cae.bin",
        "alt_start": 0,
        "alt_end": 45
      }
    ],
    "ic": { "kind": "ic_lookup_table", "params": { "grid_axes": ["f10", "kp"], "file": "ic_table.icbin" } }
  }
}
